{
  "id": "io.example.canvasdemo",
  "version": "1.0.2",
  "category": "transform",
  "displayName": "캔버스 데모 (불완전)",
  "description": "라벨이 빠진 파라미터로 C3 완결성 검사에 실패하는 음성 픽스처",
  "params": [
    { "name": "mode", "type": "string", "required": true, "label": "모드", "help": "동작 모드", "default": "fast", "widget": "select", "enumValues": ["fast", "safe"] },
    { "name": "tag", "type": "string", "required": false }
  ],
  "inputs": [
    { "name": "rows", "type": "Record[]", "label": "입력 행" }
  ],
  "outputs": [
    { "name": "out", "type": "Record[]", "label": "출력 행" }
  ],
  "forward": { "handler": "io.example.GreetBlock" },
  "idempotency": { "strategy": "NATURAL" },
  "compensation": { "reversibility": "REVERSIBLE", "kind": "NONE" },
  "retry": { "maxAttempts": 3, "backoff": { "initialMs": 100, "maxMs": 1000 } },
  "timeoutMs": 30000,
  "sideEffects": ["NONE"],
  "human": { "requireApprovalBefore": false }
}
